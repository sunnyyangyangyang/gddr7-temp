# .clangd — config for linting this kernel module with clangd.
# Place in project root alongside compile_commands.json.
#
# compile_commands.json uses $KDIR env var. Set it before launching your editor:
#   export KDIR=/lib/modules/$(uname -r)/build

CompileFlags:
  # Suppress clang-vs-gcc struct layout differences that trigger false static_assert failures
  Add: [-Wno-static-assert]
